# Proxy runtime artifacts (never commit credentials or session-specific logs)
proxy/config.json
proxy/feedback.log
proxy/proxy.out.log
proxy/proxy.err.log
proxy/.env
proxy/.env.local

# LLM session state (per-session, gitignored)
.pulseplay-session.state.json

# Claude Code session cache (per-user, never committed)
.claude/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# TypeScript build info
*.tsbuildinfo
playground/tsconfig*.tsbuildinfo

# Test output
coverage/
playground/coverage/
proxy/coverage/
playwright-report/
test-results/

# Python venvs (if you use scripts/ locally)
.venv/
__pycache__/
*.pyc

# Misc temp
.cache/
.tmp/
.databricks-app-build/
*.log

# Local HAR captures (may contain secrets)
*.har

