# PulsePlay proxy — deploy-ready env wiring (multi-Genie + Foundation + Supervisor)
# ----------------------------------------------------------------------------
# Copy to a real env (Databricks App env, Azure App Service Configuration, or a
# local `.env`) and fill the two secrets. Everything else (space IDs, endpoint
# names, display labels) is baked in so a host gets the full connector set
# WITHOUT editing config.json. Env vars MERGE over / extend config.json profiles
# (env wins per field); a profile present only here is appended.
#
# Mechanism: PROXY_PROFILE_<NAME>_<FIELD>=value  (see proxy/server.js field map).
# See docs/CONNECTOR_REQUIREMENTS.md for per-connector requirements + free-tier
# notes, and discover real serving-endpoint names via GET /api/2.0/serving-endpoints.

# ── Fill these two (same Databricks workspace for all profiles below) ────────
#   Host  = your workspace URL, e.g. https://adb-XXXX.YY.azuredatabricks.net
#   Token = a PAT (or use OAuth-M2M: set *_AUTH_MODE=oauth-m2m + *_CLIENT_ID/_CLIENT_SECRET)
PORT=7000

# ── Default Genie space (Customer) ───────────────────────────────────────────
PROXY_PROFILE_DEFAULT_HOST=https://YOUR_WORKSPACE.cloud.databricks.com
PROXY_PROFILE_DEFAULT_TOKEN=dapi_YOUR_PAT_HERE
PROXY_PROFILE_DEFAULT_SPACE_ID=01f13fe2c42f13c4a8f80254aab32c0f
PROXY_PROFILE_DEFAULT_DISPLAY_NAME=Genie: Customer
PROXY_PROFILE_DEFAULT_DATA_DOMAIN=customer & returns data

# ── Genie: Sales ─────────────────────────────────────────────────────────────
PROXY_PROFILE_SALES_HOST=https://YOUR_WORKSPACE.cloud.databricks.com
PROXY_PROFILE_SALES_TOKEN=dapi_YOUR_PAT_HERE
PROXY_PROFILE_SALES_SPACE_ID=01f13fe275b515608abb4182d0a37373
PROXY_PROFILE_SALES_DISPLAY_NAME=Genie: Sales
PROXY_PROFILE_SALES_DATA_DOMAIN=sales performance data

# ── Genie: Operations ────────────────────────────────────────────────────────
PROXY_PROFILE_OPERATIONS_HOST=https://YOUR_WORKSPACE.cloud.databricks.com
PROXY_PROFILE_OPERATIONS_TOKEN=dapi_YOUR_PAT_HERE
PROXY_PROFILE_OPERATIONS_SPACE_ID=01f13fe2ca67114cbe3d056765823125
PROXY_PROFILE_OPERATIONS_DISPLAY_NAME=Genie: Operations
PROXY_PROFILE_OPERATIONS_DATA_DOMAIN=targets & operations data

# ── Genie: HSE ───────────────────────────────────────────────────────────────
PROXY_PROFILE_HSE_HOST=https://YOUR_WORKSPACE.cloud.databricks.com
PROXY_PROFILE_HSE_TOKEN=dapi_YOUR_PAT_HERE
PROXY_PROFILE_HSE_SPACE_ID=01f13d2bcd0a1be2a333d78bca0911b6
PROXY_PROFILE_HSE_DISPLAY_NAME=Genie: HSE
PROXY_PROFILE_HSE_DATA_DOMAIN=health, safety & fulfilment data

# ── Foundation Model (serving endpoint chat + sectioned insights) ────────────
#   Endpoint MUST exist in your workspace catalog. Databricks Free Edition has
#   NO *-405b — use 3-3-70b / 3-1-8b / llama-4-maverick / claude-opus-4-8 / etc.
PROXY_PROFILE_FOUNDATION_TYPE=foundation-model
PROXY_PROFILE_FOUNDATION_HOST=https://YOUR_WORKSPACE.cloud.databricks.com
PROXY_PROFILE_FOUNDATION_TOKEN=dapi_YOUR_PAT_HERE
PROXY_PROFILE_FOUNDATION_FOUNDATION_MODEL_ENDPOINT=databricks-meta-llama-3-3-70b-instruct
PROXY_PROFILE_FOUNDATION_DISPLAY_NAME=Foundation Model — Llama 3.3 70B

# ── Supervisor (local fan-out + synthesis across the Genie spaces above) ─────
#   Pin SPACES to a small set for free-tier rate limits (Genie 5 req/min/ws).
#   Leave empty to auto-fan-out to all genie-eligible profiles.
PROXY_PROFILE_SUPERVISOR_TYPE=supervisor-local
PROXY_PROFILE_SUPERVISOR_DISPLAY_NAME=Supervisor
PROXY_PROFILE_SUPERVISOR_AGENT_NAME=PulsePlay Supervisor
PROXY_PROFILE_SUPERVISOR_SPACES=default,sales
PROXY_PROFILE_SUPERVISOR_SYNTHESIS_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

# ── Power BI semantic-model (no LLM; deterministic DAX) ──────────────────────
#   Auth via service principal or user-refresh token with dataset Read + Build.
#   PROXY_PROFILE_POWERBI_DWD_TYPE=powerbi-semantic-model
#   POWER_BI_GROUP_ID=...   POWER_BI_DATASET_ID=...
