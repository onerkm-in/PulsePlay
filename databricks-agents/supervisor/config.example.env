# Genie space IDs — pulled from the Databricks Genie space URL.
# These match the spaces currently configured in proxy/config.json.
SALES_SPACE_ID=01fENTER_YOUR_GENIE_SPACE_ID_HERE
CUSTOMER_SPACE_ID=01f13fe2c42f13c4a8f80254aab32c0f
OPS_SPACE_ID=01f13fe2ca67114cbe3d056765823125
HSE_SPACE_ID=01f13d2bcd0a1be2a333d78bca0911b6

# Foundation model that powers the supervisor's reasoning + synthesis.
# Must be a serving endpoint that exists in your workspace
# (verify with: databricks serving-endpoints list).
SUPERVISOR_LLM_ENDPOINT=databricks-meta-llama-3.1-405b-instruct

# Unity Catalog destination. The agent gets registered as
# <UC_CATALOG>.<UC_SCHEMA>.<AGENT_NAME>. You need CAN_MANAGE on the
# catalog/schema; create it first if it doesn't exist.
UC_CATALOG=workspace
UC_SCHEMA=databrickspractice
AGENT_NAME=pulseplay_supervisor_agent

# Mosaic AI serving endpoint name. Must be unique in your workspace
# (it'll fail to deploy if a same-named endpoint already exists —
# use `databricks serving-endpoints list` to check).
ENDPOINT_NAME=pulseplay-supervisor-agent
