# Pulse PBI enabler — local gitignore reinforces PulsePlay's repo-root
# rules in case patterns drift. `npm install` and `pbiviz package` will
# produce these directories inside this folder; they MUST stay untracked
# so the snapshot reflects source only.

node_modules/
dist/
.tmp/
playwright-report/
test-results/

# Webpack stats artifact (regenerated by builds)
webpack.statistics.prod.html

# OS / editor noise
.DS_Store
Thumbs.db
*.log
