{
  "name": "pulseplay-pbi",
  "description": "PulsePlay AI for Power BI — packages the live PulsePlay `playground/src/pulse` brain into a .pbiviz. Source of truth is PulsePlay; src/ is generated by scripts/sync-from-pulseplay.mjs (do not hand-edit).",
  "version": "2.1.0.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18 <25"
  },
  "scripts": {
    "sync": "node scripts/sync-from-pulseplay.mjs",
    "prepackage": "npm run sync",
    "prestart": "npm run sync",
    "pbiviz": "pbiviz",
    "start": "pbiviz start",
    "package": "pbiviz package",
    "lint": "npx eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "powerbi-visuals-api": "~5.3.0",
    "powerbi-visuals-utils-formattingmodel": "6.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sql-formatter": "^15.7.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-plugin-powerbi-visuals": "^1.0.0",
    "powerbi-visuals-tools": "^7.0.2",
    "typescript": "5.5.4"
  }
}
